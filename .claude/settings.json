{
  "version": "1.0",

  "permissions": {
    "allow": [
      "Bash(npm run lint)",
      "Bash(npm run lint:fix)",
      "Bash(npm run type-check)",
      "Bash(npm run test)",
      "Bash(npm run test:watch)",
      "Bash(npm run test:coverage)",
      "Bash(npm run test:e2e)",
      "Bash(npm run build)",
      "Bash(npm run dev)",
      "Bash(npm run db:push)",
      "Bash(npm run db:migrate)",
      "Bash(npm run db:studio)",
      "Bash(npm run db:seed)",
      "Bash(npx prisma migrate status)",
      "Bash(npx prisma migrate diff*)",
      "Bash(npx vitest*)",
      "Bash(npx tsc*)",
      "Bash(npx eslint*)",
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add*)",
      "Bash(git stash*)",
      "Bash(git branch*)",
      "Read(**)",
      "Write(src/**)",
      "Write(docs/**)",
      "Write(.claude/**)",
      "Write(tests/**)",
      "Write(public/**)",
      "Write(CLAUDE.md)",
      "Write(AGENTS.md)",
      "Write(README.md)",
      "Edit(src/**)",
      "Edit(docs/**)",
      "Edit(.claude/**)",
      "Edit(CLAUDE.md)",
      "Edit(AGENTS.md)"
    ],
    "deny": [
      "Bash(git push*)",
      "Bash(git reset --hard*)",
      "Bash(git rebase*)",
      "Bash(rm -rf*)",
      "Bash(npm install*)",
      "Bash(npm uninstall*)",
      "Bash(npx prisma migrate deploy*)",
      "Write(.env*)",
      "Write(package.json)",
      "Write(package-lock.json)",
      "Write(tsconfig.json)",
      "Write(next.config.*)",
      "Write(prisma/schema.prisma)"
    ]
  },

  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [{ "type": "command", "command": "node .claude/hooks/pre-tool-use.js" }]
      },
      {
        "matcher": "Edit",
        "hooks": [{ "type": "command", "command": "node .claude/hooks/pre-tool-use.js" }]
      },
      {
        "matcher": "Bash",
        "hooks": [{ "type": "command", "command": "node .claude/hooks/bash-guard.js" }]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [{ "type": "command", "command": "node .claude/hooks/post-tool-use.js" }]
      },
      {
        "matcher": "Edit",
        "hooks": [{ "type": "command", "command": "node .claude/hooks/post-tool-use.js" }]
      }
    ],
    "Stop": [
      {
        "hooks": [{ "type": "command", "command": "node .claude/hooks/session-end.js" }]
      }
    ]
  },

  "env": {
    "NODE_ENV": "development",
    "CLAUDE_PROJECT": "my-project",
    "CLAUDE_LOG_LEVEL": "info"
  },

  "model": "claude-sonnet-4-6",

  "includeCoAuthoredBy": true,

  "cleanupPeriodDays": 30
}
